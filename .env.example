# Bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=1310053567

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com
# Rekomendasi pakai paid RPC untuk rate limit tinggi:
# Helius: https://rpc.helius.xyz/?api-key=YOUR_KEY
# QuickNode: https://your-endpoint.quiknode.pro/YOUR_KEY
HELIUS_API_KEY=your_helius_api_key
BIRDEYE_API_KEY=your_birdeye_api_key

# EVM explorers for copy-trade polling
BSCSCAN_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_URL=https://api.bscscan.com/api
ETHERSCAN_API_URL=https://api.etherscan.io/api

# Pump.fun bonding monitor
PUMP_FUN_API_URL=https://frontend-api-v3.pump.fun/coins?offset=0&limit=50&sort=last_trade_timestamp&order=DESC&includeNsfw=false

# Settings
SCAN_INTERVAL_MS=15000
COPY_TRADE_INTERVAL_MS=30000
ANTI_RUG_INTERVAL_MS=60000
DCA_INTERVAL_MS=15000
BONDING_INTERVAL_MS=45000
VOLUME_INTERVAL_MS=120000
TIERED_TP_INTERVAL_MS=30000
